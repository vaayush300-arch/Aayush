<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Riwaaz Jewelry</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, sans-serif;
}

body{
background:#fafafa;
color:#333;
}

/* HERO */

.hero{
height:90vh;
background:url("https://i.ibb.co/ycD7yW59/1765346032878-1.png") center/cover no-repeat;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
color:white;
}

.hero-content{
background:rgba(0,0,0,0.45);
padding:40px;
border-radius:10px;
}

.hero h1{
font-size:40px;
margin-bottom:10px;
}

.hero p{
font-size:18px;
margin-bottom:20px;
}

.btn{
background:#c89b3c;
border:none;
padding:12px 24px;
color:white;
font-size:16px;
border-radius:5px;
cursor:pointer;
}

.btn:hover{
background:#a67c2f;
}

/* PRODUCTS */

.products{
padding:40px 20px;
}

.products h2{
text-align:center;
margin-bottom:30px;
}

.carousel{
display:flex;
gap:20px;
overflow-x:auto;
scroll-snap-type:x mandatory;
padding-bottom:20px;
}

.card{
min-width:220px;
background:white;
border-radius:10px;
box-shadow:0 5px 15px rgba(0,0,0,0.1);
padding:15px;
text-align:center;
scroll-snap-align:start;
}

.card img{
width:100%;
border-radius:10px;
margin-bottom:10px;
}

.price{
color:#c89b3c;
font-weight:bold;
margin:5px 0;
}

.add{
background:black;
color:white;
border:none;
padding:8px 14px;
border-radius:5px;
cursor:pointer;
}

/* CART ICON */

.cart{
position:fixed;
top:20px;
right:20px;
background:black;
color:white;
padding:12px;
border-radius:50%;
font-size:18px;
cursor:pointer;
}

.cart-count{
position:absolute;
top:-5px;
right:-5px;
background:red;
color:white;
font-size:12px;
padding:3px 6px;
border-radius:50%;
}

/* CART MODAL */

.cart-modal{
position:fixed;
bottom:0;
left:0;
right:0;
background:white;
padding:20px;
box-shadow:0 -5px 20px rgba(0,0,0,0.2);
display:none;
max-height:70vh;
overflow:auto;
}

.cart-modal h3{
margin-bottom:10px;
}

.cart-items{
margin-bottom:15px;
}

input{
width:100%;
padding:10px;
margin-bottom:10px;
border:1px solid #ddd;
border-radius:5px;
}

/* WHATSAPP BUTTON */

.whatsapp{
position:fixed;
bottom:20px;
right:20px;
background:#25D366;
color:white;
font-size:26px;
padding:12px 16px;
border-radius:50%;
text-decoration:none;
}

</style>
</head>

<body>

<!-- CART ICON -->

<div class="cart" onclick="toggleCart()">
🛒
<span class="cart-count" id="cartCount">0</span>
</div>


<!-- HERO -->

<section class="hero">

<div class="hero-content">

<h1>Riwaaz Jewelry</h1>

<p>Tradition Meets Modernity</p>

<button class="btn" onclick="scrollToProducts()">Shop Now</button>

</div>

</section>



<!-- PRODUCTS -->

<section class="products" id="products">

<h2>Our Collection</h2>

<div class="carousel">

<div class="card">
<img src="https://i.ibb.co/gFzSPbpX/1764569334212.png">
<h4>Gold Necklace</h4>
<p class="price">₹1,499</p>
<button class="add" onclick="addToCart('Gold Necklace')">Add to Cart</button>
</div>

<div class="card">
<img src="https://i.ibb.co/mC05dhX8/1764569526024.png">
<h4>Elegant Earrings</h4>
<p class="price">₹899</p>
<button class="add" onclick="addToCart('Elegant Earrings')">Add to Cart</button>
</div>

</div>

</section>


<!-- CART MODAL -->

<div class="cart-modal" id="cartModal">

<h3>Your Cart</h3>

<div class="cart-items" id="cartItems"></div>

<input id="customerName" placeholder="Your Name">

<input id="customerPhone" placeholder="Phone Number">

<button class="btn" onclick="sendOrder()">Place Order</button>

</div>



<!-- WHATSAPP -->

<a class="whatsapp" href="https://wa.me/917992097130" target="_blank">
💬
</a>



<script>

let cart=[]

function scrollToProducts(){
document.getElementById("products").scrollIntoView({behavior:"smooth"})
}

function addToCart(product){

cart.push(product)

document.getElementById("cartCount").innerText=cart.length

updateCart()

}

function updateCart(){

let container=document.getElementById("cartItems")

container.innerHTML=""

cart.forEach(item=>{

let div=document.createElement("div")

div.innerText=item

container.appendChild(div)

})

}

function toggleCart(){

let modal=document.getElementById("cartModal")

modal.style.display= modal.style.display==="block" ? "none":"block"

}

function sendOrder(){

let name=document.getElementById("customerName").value
let phone=document.getElementById("customerPhone").value

let items=cart.join(", ")

let subject="New Jewelry Order"

let body=`Customer Name: ${name}%0D%0APhone: ${phone}%0D%0AItems: ${items}`

window.location.href=`mailto:riwaaz485@gmail.com?subject=${subject}&body=${body}`

}

</script>

</body>
</html>
